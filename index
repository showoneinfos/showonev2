<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ShowOne — La plateforme des talents</title>
  <meta name="description" content="ShowOne connecte les talents avec les recruteurs. Inscris-toi gratuitement, poste ta vidéo et fais-toi remarquer.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,700;0,900;1,900&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; background: #fff; color: #111; }

    /* NAV */
    nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 40px;
      border-bottom: 1px solid #f0f0f0;
      position: sticky; top: 0; background: #fff; z-index: 100;
    }
    .logo { font-size: 20px; font-weight: 900; color: #111; letter-spacing: -0.5px; text-decoration: none; }
    .logo span { color: #E8383A; }
    .nav-links { display: flex; gap: 28px; font-size: 13px; color: #999; }
    .nav-links a { color: #999; text-decoration: none; }
    .nav-links a:hover { color: #111; }
    .nav-cta { display: flex; gap: 10px; align-items: center; }
    .btn-ghost { padding: 8px 16px; font-size: 13px; border-radius: 8px; border: 1px solid #e0e0e0; background: transparent; color: #333; cursor: pointer; font-weight: 500; }
    .btn-ghost:hover { border-color: #bbb; }
    .btn-red { padding: 8px 18px; font-size: 13px; font-weight: 700; border-radius: 8px; background: #E8383A; color: #fff; border: none; cursor: pointer; }
    .btn-red:hover { background: #cc2e30; }

    /* NAV CONNECTE */
    #nav-connecte { display: none; align-items: center; gap: 12px; }
    .nav-prenom { font-size: 13px; font-weight: 600; color: #111; }
    .btn-deco { padding: 8px 14px; font-size: 12px; border-radius: 8px; border: 1px solid #e0e0e0; background: transparent; color: #999; cursor: pointer; }

    /* HERO */
    .hero {
      padding: 72px 40px 64px;
      display: flex; align-items: flex-end; justify-content: space-between; gap: 40px;
      border-bottom: 1px solid #f0f0f0;
      max-width: 1200px; margin: 0 auto;
    }
    .hero-left { flex: 1; }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 10px;
      font-size: 11px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
      color: #bbb; margin-bottom: 28px;
    }
    .hero-eyebrow-line { width: 28px; height: 1px; background: #ddd; }
    .hero-h1 { font-size: 68px; font-weight: 900; line-height: 1.02; letter-spacing: -3px; color: #111; }
    .hero-h1-italic { font-size: 68px; font-weight: 900; line-height: 1.02; letter-spacing: -3px; font-style: italic; color: #E8383A; }
    .hero-right { flex: 0 0 300px; padding-bottom: 6px; }
    .hero-sub { font-size: 15px; color: #999; line-height: 1.65; margin-bottom: 28px; }
    .hero-btns { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
    .btn-black { padding: 14px 28px; font-size: 14px; font-weight: 700; border-radius: 10px; background: #111; color: #fff; border: none; cursor: pointer; }
    .btn-black:hover { background: #333; }
    .btn-link { font-size: 14px; color: #999; cursor: pointer; font-weight: 500; background: none; border: none; }
    .btn-link:hover { color: #111; }
    .hero-stats { display: flex; gap: 28px; margin-top: 36px; padding-top: 28px; border-top: 1px solid #f0f0f0; }
    .stat-n { font-size: 22px; font-weight: 900; color: #111; letter-spacing: -0.5px; }
    .stat-l { font-size: 11px; color: #bbb; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }

    /* SECTION */
    .section-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 36px 40px 18px;
      max-width: 1200px; margin: 0 auto;
    }
    .section-title { font-size: 16px; font-weight: 700; color: #111; }
    .section-right { display: flex; align-items: center; gap: 10px; }
    .cats { display: flex; gap: 6px; flex-wrap: wrap; }
    .cat {
      padding: 6px 14px; border-radius: 100px; font-size: 12px; font-weight: 500;
      border: 1px solid #e8e8e8; color: #888; cursor: pointer; background: #fff;
      transition: all 0.15s;
    }
    .cat:hover { border-color: #ccc; color: #333; }
    .cat.active { background: #111; border-color: #111; color: #fff; }
    .see-all { font-size: 12px; color: #E8383A; cursor: pointer; font-weight: 500; text-decoration: none; }

    /* GRILLE TALENTS */
    .talent-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      padding: 0 40px 48px;
      max-width: 1200px; margin: 0 auto;
    }
    .talent-card {
      border-radius: 12px; overflow: hidden;
      background: #fff; border: 1px solid #f0f0f0;
      cursor: pointer; transition: box-shadow 0.15s;
    }
    .talent-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    .card-thumb {
      aspect-ratio: 3/4; position: relative; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .card-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .card-thumb-placeholder {
      width: 100%; height: 100%;
      display: flex; align-items: center; justify-content: center;
      font-size: 32px; font-weight: 900; color: rgba(0,0,0,0.1); letter-spacing: -1px;
    }
    .card-cat-pill {
      position: absolute; top: 10px; left: 10px;
      font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px;
      padding: 4px 9px; border-radius: 100px; background: #111; color: #fff;
    }
    .card-play {
      position: absolute; bottom: 10px; right: 10px;
      width: 34px; height: 34px; border-radius: 50%;
      background: #E8383A; display: flex; align-items: center; justify-content: center;
      font-size: 12px; color: #fff;
    }
    .card-info { padding: 12px 14px 14px; }
    .card-name { font-size: 14px; font-weight: 700; color: #111; }
    .card-meta { font-size: 11px; color: #ccc; margin-top: 3px; }

    /* LOADING */
    .loading { text-align: center; padding: 60px; color: #bbb; font-size: 14px; }
    .empty { text-align: center; padding: 60px; color: #bbb; font-size: 14px; }

    /* BANNER RECRUTEURS */
    .recruiter-banner {
      margin: 0 40px 48px;
      max-width: 1120px; margin-left: auto; margin-right: auto;
      margin-bottom: 48px;
      padding: 36px 40px;
      border-radius: 16px;
      border: 1px solid #f0f0f0;
      display: flex; align-items: center; justify-content: space-between; gap: 24px;
    }
    .banner-text h3 { font-size: 20px; font-weight: 900; color: #111; letter-spacing: -0.5px; margin-bottom: 6px; }
    .banner-text p { font-size: 13px; color: #999; }
    .btn-banner { padding: 13px 26px; font-size: 14px; font-weight: 700; border-radius: 10px; background: #E8383A; color: #fff; border: none; cursor: pointer; white-space: nowrap; }
    .btn-banner:hover { background: #cc2e30; }

    /* MODAL VIDEO */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.85); z-index: 1000;
      align-items: center; justify-content: center;
    }
    .modal-overlay.open { display: flex; }
    .modal-box {
      background: #fff; border-radius: 16px; overflow: hidden;
      width: 90%; max-width: 480px; position: relative;
    }
    .modal-close {
      position: absolute; top: 12px; right: 12px;
      width: 32px; height: 32px; border-radius: 50%;
      background: rgba(0,0,0,0.5); color: #fff; border: none;
      font-size: 16px; cursor: pointer; display: flex; align-items: center; justify-content: center;
      z-index: 10;
    }
    .modal-video { width: 100%; aspect-ratio: 9/16; background: #000; }
    .modal-video video { width: 100%; height: 100%; object-fit: cover; }
    .modal-info { padding: 16px 20px; }
    .modal-name { font-size: 16px; font-weight: 700; color: #111; }
    .modal-cat { font-size: 12px; color: #999; margin-top: 3px; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      nav { padding: 14px 20px; }
      .nav-links { display: none; }
      .hero { flex-direction: column; padding: 40px 20px; gap: 24px; }
      .hero-h1, .hero-h1-italic { font-size: 44px; letter-spacing: -2px; }
      .hero-right { flex: none; width: 100%; }
      .hero-stats { gap: 20px; }
      .section-header { padding: 28px 20px 14px; }
      .talent-grid { grid-template-columns: repeat(2, 1fr); padding: 0 20px 32px; gap: 12px; }
      .recruiter-banner { margin: 0 20px 32px; flex-direction: column; align-items: flex-start; padding: 24px; }
    }

    /* COULEURS PLACEHOLDER */
    .bg-lavender { background: #f0ecfa; }
    .bg-mint { background: #eaf4ef; }
    .bg-blush { background: #faeaec; }
    .bg-sky { background: #eaf0fa; }
    .bg-peach { background: #faf0ea; }
    .bg-sage { background: #eefaea; }
    .bg-lilac { background: #f5eaf5; }
    .bg-ice { background: #eaf5f5; }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="index.html" class="logo">Show<span>One</span></a>
  <div class="nav-links">
    <a href="#">Découvrir</a>
    <a href="#">Castings</a>
    <a href="#">Recruteurs</a>
  </div>
  <div id="nav-deconnecte" class="nav-cta">
    <button class="btn-ghost" onclick="window.location.href='connexion.html'">Connexion</button>
    <button class="btn-red" onclick="window.location.href='inscription.html'">Rejoindre</button>
  </div>
  <div id="nav-connecte">
    <span class="nav-prenom" id="nav-prenom"></span>
    <button class="btn-ghost" onclick="window.location.href='dashboard.html'">Mon espace</button>
    <button class="btn-deco" onclick="seDeconnecter()">Déconnexion</button>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-left">
    <div class="hero-eyebrow">
      <div class="hero-eyebrow-line"></div>
      Plateforme de talents · France
    </div>
    <div class="hero-h1">Ton talent</div>
    <div class="hero-h1">mérite</div>
    <div class="hero-h1-italic">d'être vu.</div>
  </div>
  <div class="hero-right">
    <p class="hero-sub">Inscris-toi gratuitement, poste ta vidéo et connecte-toi avec des recruteurs partout en France.</p>
    <div class="hero-btns">
      <button class="btn-black" onclick="window.location.href='inscription.html'">Inscris-toi gratuitement</button>
      <button class="btn-link">Voir les talents ↓</button>
    </div>
    <div class="hero-stats">
      <div id="stat-talents">
        <div class="stat-n">—</div>
        <div class="stat-l">Talents</div>
      </div>
      <div>
        <div class="stat-n">100%</div>
        <div class="stat-l">Gratuit</div>
      </div>
      <div>
        <div class="stat-n">🇫🇷</div>
        <div class="stat-l">France</div>
      </div>
    </div>
  </div>
</div>

<!-- TALENTS -->
<div class="section-header">
  <div class="section-title">Talents du moment</div>
  <div class="section-right">
    <div class="cats">
      <div class="cat active" onclick="filtrerCat(this, '')">Tous</div>
      <div class="cat" onclick="filtrerCat(this, 'Danse')">Danse</div>
      <div class="cat" onclick="filtrerCat(this, 'Chant')">Chant</div>
      <div class="cat" onclick="filtrerCat(this, 'Humour')">Humour</div>
      <div class="cat" onclick="filtrerCat(this, 'Sport')">Sport</div>
      <div class="cat" onclick="filtrerCat(this, 'Musique')">Musique</div>
    </div>
    <a href="#" class="see-all">Voir tous →</a>
  </div>
</div>

<div class="talent-grid" id="talent-grid">
  <div class="loading">Chargement des talents...</div>
</div>

<!-- BANNER RECRUTEURS -->
<div class="recruiter-banner">
  <div class="banner-text">
    <h3>Vous recrutez des talents ?</h3>
    <p>Accédez à des centaines de profils vérifiés. Gratuit pour commencer.</p>
  </div>
  <button class="btn-banner" onclick="window.location.href='inscription.html?type=recruteur'">Créer un compte recruteur</button>
</div>

<!-- MODAL VIDEO -->
<div class="modal-overlay" id="modal" onclick="fermerModal(event)">
  <div class="modal-box">
    <button class="modal-close" onclick="fermerModal()">✕</button>
    <div class="modal-video">
      <video id="modal-video" controls playsinline></video>
    </div>
    <div class="modal-info">
      <div class="modal-name" id="modal-name"></div>
      <div class="modal-cat" id="modal-cat"></div>
    </div>
  </div>
</div>

<script>
  const SUPABASE_URL = 'https://emiuzigtlomlrsofxqyf.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVtaXV6aWd0bG9tbHJzb2Z4cXlmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDYzNjE3MzcsImV4cCI6MjA2MTkzNzczN30.8DBZX_lKXaKlKQLqMKVRYrMNASMY5_4mHpZVMBBjPOc';
  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  const bgColors = ['bg-lavender','bg-mint','bg-blush','bg-sky','bg-peach','bg-sage','bg-lilac','bg-ice'];
  let tousTalents = [];
  let catActive = '';

  async function init() {
    // Vérif session
    const { data: { session } } = await sb.auth.getSession();
    if (session) {
      document.getElementById('nav-deconnecte').style.display = 'none';
      document.getElementById('nav-connecte').style.display = 'flex';
      const prenom = window.localStorage.getItem('so_prenom') || session.user.email.split('@')[0];
      document.getElementById('nav-prenom').textContent = prenom;
    }

    // Charger talents
    const { data, error } = await sb
      .from('profils_talents')
      .select('id, nom, prenom, categorie, ville, videos(url_video, url_thumbnail, mux_playback_id)')
      .order('created_at', { ascending: false })
      .limit(12);

    if (error || !data) {
      document.getElementById('talent-grid').innerHTML = '<div class="empty">Aucun talent pour le moment.</div>';
      return;
    }

    tousTalents = data;

    // Stat
    const { count } = await sb.from('profils_talents').select('*', { count: 'exact', head: true });
    if (count) {
      document.querySelector('#stat-talents .stat-n').textContent = count + '+';
    }

    afficherTalents(tousTalents);
  }

  function afficherTalents(liste) {
    const grid = document.getElementById('talent-grid');
    if (!liste.length) {
      grid.innerHTML = '<div class="empty">Aucun talent dans cette catégorie.</div>';
      return;
    }
    grid.innerHTML = liste.map((t, i) => {
      const nom = (t.prenom || '') + ' ' + (t.nom || '');
      const initiales = ((t.prenom || '')[0] || '') + ((t.nom || '')[0] || '');
      const cat = t.categorie || '';
      const ville = t.ville || '';
      const video = t.videos && t.videos[0];
      const bg = bgColors[i % bgColors.length];

      let thumbHtml = '';
      if (video && video.mux_playback_id) {
        thumbHtml = `<img src="https://image.mux.com/${video.mux_playback_id}/thumbnail.jpg?width=400" alt="${nom}" onerror="this.style.display='none'">`;
      } else if (video && video.url_thumbnail) {
        thumbHtml = `<img src="${video.url_thumbnail}" alt="${nom}" onerror="this.style.display='none'">`;
      }

      const videoUrl = video ? (video.url_video || (video.mux_playback_id ? `https://stream.mux.com/${video.mux_playback_id}.m3u8` : '')) : '';

      return `
        <div class="talent-card" onclick="ouvrirModal('${videoUrl}', '${nom.trim()}', '${cat}')">
          <div class="card-thumb ${!thumbHtml ? bg : ''}">
            ${thumbHtml || `<div class="card-thumb-placeholder">${initiales.toUpperCase()}</div>`}
            ${cat ? `<div class="card-cat-pill">${cat}</div>` : ''}
            ${videoUrl ? `<div class="card-play">▶</div>` : ''}
          </div>
          <div class="card-info">
            <div class="card-name">${nom.trim() || 'Talent'}</div>
            <div class="card-meta">${ville}</div>
          </div>
        </div>
      `;
    }).join('');
  }

  function filtrerCat(el, cat) {
    document.querySelectorAll('.cat').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
    catActive = cat;
    const filtres = cat ? tousTalents.filter(t => t.categorie === cat) : tousTalents;
    afficherTalents(filtres);
  }

  function ouvrirModal(url, nom, cat) {
    if (!url) return;
    document.getElementById('modal-video').src = url;
    document.getElementById('modal-name').textContent = nom;
    document.getElementById('modal-cat').textContent = cat;
    document.getElementById('modal').classList.add('open');
    document.getElementById('modal-video').play();
  }

  function fermerModal(e) {
    if (e && e.target !== document.getElementById('modal') && !e.target.classList.contains('modal-close')) return;
    document.getElementById('modal-video').pause();
    document.getElementById('modal-video').src = '';
    document.getElementById('modal').classList.remove('open');
  }

  async function seDeconnecter() {
    await sb.auth.signOut();
    window.localStorage.clear();
    window.location.reload();
  }

  init();
</script>
</body>
</html>
